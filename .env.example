# Copy file này thành `.env` rồi điền key cho provider bạn dùng.
# (Đừng commit `.env` lên git — đã có trong .gitignore.)

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Tuỳ chọn thêm provider:
# DEEPSEEK_API_KEY=
# XAI_API_KEY=

# Chạy thử KHÔNG cần key (dùng model giả lập để xem luồng + UI):
# THEOSIS_DEMO=1

# Trỏ tới file config khác (mặc định config.yaml):
# THEOSIS_CONFIG=config.yaml
